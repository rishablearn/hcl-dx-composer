# =============================================================================
# HCL DX Composer - Environment Configuration
# =============================================================================
# Copy this file to .env and customize your settings
# Or run: ./scripts/setup.sh (recommended)
#
# DEPLOYMENT SEQUENCE:
#   1. ./scripts/setup.sh    → Creates .env with your settings
#   2. ./scripts/deploy.sh --build → Builds and starts all services
#   3. ./scripts/deploy.sh --status → Verify deployment
#
# =============================================================================

# =============================================================================
# GROUP 1: CORE INFRASTRUCTURE (Required)
# =============================================================================

# -----------------------------------------------------------------------------
# 1.1 General Settings
# -----------------------------------------------------------------------------
NODE_ENV=production

# -----------------------------------------------------------------------------
# 1.2 Database (PostgreSQL)
# Auto-configured by setup.sh with secure passwords
# -----------------------------------------------------------------------------
POSTGRES_DB=hcl_dx_staging
POSTGRES_USER=hcldx
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# 1.3 Backend Service
# -----------------------------------------------------------------------------
BACKEND_PORT=3001
JWT_SECRET=your_jwt_secret_change_in_production_min_32_chars
SESSION_SECRET=your_session_secret_change_in_production_min_32_chars

# -----------------------------------------------------------------------------
# 1.4 Frontend Service
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:3001/api

# =============================================================================
# GROUP 2: AUTHENTICATION (Choose One Mode)
# =============================================================================

# -----------------------------------------------------------------------------
# 2.1 LDAP Mode Selection
# Options: 'local' (Docker OpenLDAP) or 'common' (External AD/LDAP)
# -----------------------------------------------------------------------------
LDAP_MODE=local

# -----------------------------------------------------------------------------
# 2.2 Local LDAP Settings (when LDAP_MODE=local)
# Pre-configured users: admin, author, reviewer, publisher (password: 'password')
# -----------------------------------------------------------------------------
LDAP_URL=ldap://openldap:389
LDAP_BASE_DN=dc=hcldx,dc=local
LDAP_BIND_DN=cn=admin,dc=hcldx,dc=local
LDAP_BIND_PASSWORD=admin_password
LDAP_USER_SEARCH_BASE=ou=Users,dc=hcldx,dc=local
LDAP_GROUP_SEARCH_BASE=ou=Groups,dc=hcldx,dc=local

# Local LDAP Container Settings
LDAP_ADMIN_PASSWORD=admin_password
LDAP_CONFIG_PASSWORD=config_password
LDAP_ORGANISATION=HCL DX Composer
LDAP_DOMAIN=hcldx.local
LDAP_PORT=389

# -----------------------------------------------------------------------------
# 2.3 Common LDAP Settings (when LDAP_MODE=common)
# Uncomment and configure for enterprise AD/LDAP
# -----------------------------------------------------------------------------
# LDAP_URL=ldap://your-ad-server.domain.com:389
# LDAP_BASE_DN=DC=domain,DC=com
# LDAP_BIND_DN=CN=ServiceAccount,OU=ServiceAccounts,DC=domain,DC=com
# LDAP_BIND_PASSWORD=your_ldap_bind_password
# LDAP_USER_SEARCH_BASE=OU=Users,DC=domain,DC=com
# LDAP_GROUP_SEARCH_BASE=OU=Groups,DC=domain,DC=com

# =============================================================================
# GROUP 3: HCL DX INTEGRATION (Required for Production)
# =============================================================================

# -----------------------------------------------------------------------------
# 3.1 HCL DX Server Connection
# -----------------------------------------------------------------------------
HCL_DX_HOST=your-dx-server.domain.com
HCL_DX_PORT=443
HCL_DX_PROTOCOL=https

# -----------------------------------------------------------------------------
# 3.2 HCL DX Authentication
# Service account credentials for API access
# -----------------------------------------------------------------------------
HCL_DX_USERNAME=wcmservice
HCL_DX_PASSWORD=your_service_account_password

# -----------------------------------------------------------------------------
# 3.3 HCL DX WCM API
# -----------------------------------------------------------------------------
HCL_DX_WCM_BASE_URL=https://your-dx-server.domain.com/wps/mycontenthandler/wcmrest
HCL_DX_WCM_LIBRARY=Web Content

# -----------------------------------------------------------------------------
# 3.4 HCL DX DAM API
# -----------------------------------------------------------------------------
HCL_DX_DAM_BASE_URL=https://your-dx-server.domain.com/dx/api/dam/v1

# -----------------------------------------------------------------------------
# 3.5 LTPA2 SSO (Optional - for Portal SSO)
# -----------------------------------------------------------------------------
LTPA2_SECRET_KEY=your_ltpa2_secret_key_base64_encoded
LTPA2_REALM=your_realm

# =============================================================================
# GROUP 4: AI IMAGE GENERATION (Optional)
# =============================================================================

# -----------------------------------------------------------------------------
# 4.1 AI Provider Selection
# Options: pollinations, cloudflare, openai, stability, gemini, huggingface
# -----------------------------------------------------------------------------
AI_IMAGE_PROVIDER=pollinations

# -----------------------------------------------------------------------------
# 4.2 Pollinations AI (Free - No API Key Required)
# Unlimited usage, instant start
# -----------------------------------------------------------------------------
POLLINATIONS_ENABLED=true

# -----------------------------------------------------------------------------
# 4.3 Cloudflare Workers AI (Free Tier: 10k neurons/day)
# Get credentials: https://dash.cloudflare.com/
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/black-forest-labs/flux-1-schnell

# -----------------------------------------------------------------------------
# 4.4 OpenAI DALL-E (Paid)
# Get API key: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# 4.5 Stability AI (Paid)
# Get API key: https://platform.stability.ai/
# -----------------------------------------------------------------------------
STABILITY_API_KEY=

# -----------------------------------------------------------------------------
# 4.6 Google Gemini (Free Tier: 60 req/min)
# Get API key: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GOOGLE_AI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp-image-generation

# -----------------------------------------------------------------------------
# 4.7 Hugging Face (Free Tier: Limited)
# Get token: https://huggingface.co/settings/tokens
# -----------------------------------------------------------------------------
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=black-forest-labs/FLUX.1-schnell

# =============================================================================
# GROUP 5: FILE UPLOADS
# =============================================================================
MAX_UPLOAD_SIZE=52428800
UPLOAD_PATH=/var/uploads
